{
    "name": "@rchemist/listgrid",
    "version": "0.2.8",
    "private": false,
    "description": "Framework-free React CRUD UI engine — primitive-based design system, data-attr theming, and a full list/form renderer for RCM-framework-style entity backends.",
    "keywords": [
        "react",
        "listgrid",
        "crud",
        "entity",
        "form",
        "table",
        "design-system",
        "css-primitives",
        "data-attr",
        "framework-free"
    ],
    "author": "rchemist.io",
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./next": {
            "types": "./dist/adapters/next/index.d.ts",
            "default": "./dist/adapters/next/index.js"
        },
        "./form/SearchForm": {
            "types": "./dist/listgrid/form/SearchForm.d.ts",
            "default": "./dist/listgrid/form/SearchForm.js"
        },
        "./form/Type": {
            "types": "./dist/listgrid/form/Type.d.ts",
            "default": "./dist/listgrid/form/Type.js"
        },
        "./api": {
            "types": "./dist/listgrid/api/index.d.ts",
            "default": "./dist/listgrid/api/index.js"
        },
        "./misc": {
            "types": "./dist/listgrid/misc/index.d.ts",
            "default": "./dist/listgrid/misc/index.js"
        },
        "./styles.css": "./dist/styles.css",
        "./styles/tokens.css": "./dist/styles/tokens.css",
        "./styles/primitives.css": "./dist/styles/primitives.css",
        "./styles/layouts.css": "./dist/styles/layouts.css",
        "./styles/components.css": "./dist/styles/components.css",
        "./styles/base.css": "./dist/styles/base.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "docs/PRIMITIVES.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rchemist/rcm-listgrid.git"
    },
    "bugs": {
        "url": "https://github.com/rchemist/rcm-listgrid/issues"
    },
    "homepage": "https://github.com/rchemist/rcm-listgrid#readme",
    "scripts": {
        "type-check": "tsc --noEmit",
        "build": "tsc -p tsconfig.build.json && npm run build:styles",
        "build:styles": "mkdir -p dist/styles && cp src/listgrid/styles/tokens.css src/listgrid/styles/primitives.css src/listgrid/styles/layouts.css src/listgrid/styles/components.css src/listgrid/styles/base.css dist/styles/ && cat src/listgrid/styles/tokens.css src/listgrid/styles/primitives.css src/listgrid/styles/layouts.css src/listgrid/styles/components.css src/listgrid/styles/base.css > dist/styles.css",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run type-check && npm test && npm run build",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
        "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
        "format:check": "prettier --check 'src/**/*.{ts,tsx,css,json}'",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "docs": "typedoc",
        "docs:watch": "typedoc --watch"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "crypto-js": "^4.2.0",
        "tailwind-merge": "^2.5.4",
        "uuid": "^9.0.0",
        "zustand": "^4.4.0"
    },
    "peerDependencies": {
        "@headlessui/react": "^2.0.0",
        "@iconify/react": "^4.0.0 || ^5.0.0",
        "@tabler/icons-react": "^2.30.0 || ^3.0.0",
        "date-fns": "^2.0.0 || ^3.0.0 || ^4.0.0",
        "file-saver": "^2.0.5",
        "next": ">=14",
        "nuqs": ">=2.0.0",
        "qrcode.react": "^3.0.0 || ^4.0.0",
        "react": ">=18",
        "react-daum-postcode": "^3.0.0",
        "react-dom": ">=18",
        "react-kakao-maps-sdk": "^1.0.0",
        "react-select": "^5.0.0",
        "react-sortablejs": "^6.0.0 || ^7.0.0",
        "sweetalert2": "^11.0.0",
        "sweetalert2-react-content": "^5.0.0",
        "xlsx-js-style": "^1.2.0"
    },
    "peerDependenciesMeta": {
        "@tabler/icons-react": {
            "optional": false
        },
        "@headlessui/react": {
            "optional": false
        },
        "next": {
            "optional": true
        },
        "nuqs": {
            "optional": true
        },
        "@iconify/react": {
            "optional": true
        },
        "react-select": {
            "optional": true
        },
        "react-sortablejs": {
            "optional": true
        },
        "qrcode.react": {
            "optional": true
        },
        "react-kakao-maps-sdk": {
            "optional": true
        },
        "react-daum-postcode": {
            "optional": true
        },
        "xlsx-js-style": {
            "optional": true
        },
        "file-saver": {
            "optional": true
        },
        "sweetalert2": {
            "optional": true
        },
        "sweetalert2-react-content": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@headlessui/react": "^2.2.9",
        "@iconify/react": "^4.1.1",
        "@tabler/icons-react": "^2.30.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/crypto-js": "^4.2.2",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^22.0.2",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.0",
        "@types/sortablejs": "^1.15.9",
        "@types/uuid": "^9.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitest/coverage-v8": "^4.1.4",
        "date-fns": "^3.6.0",
        "eslint": "^10.2.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "file-saver": "^2.0.5",
        "globals": "^16.5.0",
        "jsdom": "^29.0.2",
        "next": "^15.0.0",
        "nuqs": "^2.0.0",
        "prettier": "^3.8.3",
        "qrcode.react": "^3.1.0",
        "react": "^19.2.1",
        "react-daum-postcode": "^3.1.3",
        "react-dom": "^19.2.1",
        "react-kakao-maps-sdk": "^1.1.27",
        "react-select": "^5.10.2",
        "react-sortablejs": "^6.1.4",
        "sortablejs": "^1.15.7",
        "sweetalert2": "^11.6.13",
        "sweetalert2-react-content": "^5.0.7",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4",
        "xlsx-js-style": "^1.2.0"
    }
}
